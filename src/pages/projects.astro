---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

const avallainProducts = [
  {
    name: 'Avallain Unity',
    summary: 'Core architecture powering all Avallain products. Scalable AWS infrastructure serving millions of learners.',
    url: 'https://www.avallain.com/services/technology/custom-platform-development',
    icon: '🎓'
  },
  {
    name: 'Avallain Magnet',
    summary: 'AI-integrated learning management system with adaptive learning paths and progress tracking.',
    url: 'https://www.avallain.com/products/magnet',
    icon: '🧲'
  },
  {
    name: 'Avallain Author',
    summary: 'AI-powered authoring tool with 40+ activity types for creating interactive educational content.',
    url: 'https://www.avallain.com/products/author',
    icon: '✍️'
  },
  {
    name: 'TeacherMatic',
    summary: 'AI toolkit for teachers to create lesson plans, worksheets and quizzes in seconds.',
    url: 'https://www.avallain.com/services/technology/artificial-intelligence',
    icon: '🤖'
  }
];
---

<BaseLayout title="Projects" description="Projects and products I've contributed to as a software architect.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="text-center mb-16">
      <h1 class="section-title">Projects</h1>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Products and platforms I've helped architect and build, from EdTech solutions serving millions of users to startup applications.
      </p>
    </div>

    <h2 class="text-xl font-bold text-primary mb-6">Avallain Products</h2>
    <p class="text-gray-600 mb-8">
      As Director of Technology at Avallain, I've contributed to the architecture, development and AWS cloud deployment of these AI-powered educational platforms trusted by Oxford University Press, Pearson, Cambridge, and other leading publishers.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
      {avallainProducts.map((product) => (
        <a href={product.url} target="_blank" rel="noopener noreferrer" class="card" style="text-decoration: none;">
          <div class="flex items-start" style="gap: 1rem;">
            <span style="font-size: 2rem;">{product.icon}</span>
            <div>
              <h3 class="font-semibold text-primary mb-2">{product.name}</h3>
              <p class="text-sm text-gray-600">{product.summary}</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <h2 class="text-xl font-bold text-primary mb-6">Past Projects</h2>
    <p class="text-gray-600 mb-8">
      Earlier work from my freelancing years, building web applications for startups across Spain.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {projects.map((project) => (
        <ProjectCard 
          name={project.name}
          summary={project.summary}
          image={project.folder}
          url={project.url}
        />
      ))}
    </div>
  </section>
</BaseLayout>
