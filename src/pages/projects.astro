---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

const avallainProducts = [
  {
    name: 'Avallain Unity',
    summary: 'Core architecture powering all Avallain products. Scalable AWS infrastructure serving millions of learners.',
    url: 'https://www.avallain.com/services/technology/custom-platform-development',
  },
  {
    name: 'Avallain Magnet',
    summary: 'AI-integrated learning management system with adaptive learning paths and progress tracking.',
    url: 'https://www.avallain.com/products/magnet',
  },
  {
    name: 'Avallain Author',
    summary: 'AI-powered authoring tool with 40+ activity types for creating interactive educational content.',
    url: 'https://www.avallain.com/products/author',
  },
  {
    name: 'TeacherMatic',
    summary: 'AI toolkit for teachers to create lesson plans, worksheets and quizzes in seconds.',
    url: 'https://www.avallain.com/services/technology/artificial-intelligence',
  }
];
---

<BaseLayout title="Projects" description="Projects and products I've contributed to as a software architect.">
  <section class="section shell" aria-labelledby="projects-heading">
    <header class="section-heading">
      <span class="section-kicker">Selected Work</span>
      <h1 id="projects-heading">Projects</h1>
      <p class="section-description">
        Products I've helped architect and build, from EdTech solutions serving millions of learners to startup applications across Europe and the US.
      </p>
    </header>

    <div class="project-group">
      <div class="project-group-header">
        <h2 class="project-group-title">Avallain Products</h2>
        <p class="project-group-description">
          As Director of Technology at Avallain, I guide the architecture, development, and AWS delivery of these AI-powered educational products used by leading publishers including Oxford University Press, Cengage, Pearson, and Cambridge.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {avallainProducts.map((product) => (
          <a href={product.url} target="_blank" rel="noopener noreferrer" class="card card-link project-overview-card">
            <span class="project-kicker">Product</span>
            <h3 class="font-semibold text-heading">{product.name}</h3>
            <p class="text-sm text-muted">{product.summary}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="project-group section-divider">
      <div class="project-group-header">
        <h2 class="project-group-title">Past Projects</h2>
        <p class="project-group-description">
          Earlier work from my freelancing years, helping startups launch their first scalable products.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {projects.map((project) => (
          <ProjectCard 
            name={project.name}
            summary={project.summary}
            image={project.folder}
            url={project.url}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .project-group {
    display: grid;
    gap: clamp(1.5rem, 4vw, var(--space-10));
    margin-top: clamp(2rem, 4vw + 1rem, var(--space-12));
  }

  .project-group:first-of-type {
    margin-top: 0;
  }

  .project-group.section-divider {
    margin-top: 0;
  }

  .project-group-header {
    display: grid;
    gap: var(--space-3);
    max-width: 48rem;
  }

  .project-group-title {
    font-size: var(--text-2xl);
    color: var(--color-primary);
  }

  .project-group-description {
    color: var(--color-text-muted);
  }

  .project-overview-card {
    gap: var(--space-2);
  }

  @media (max-width: 640px) {
    .project-group-header {
      max-width: 100%;
    }
  }
</style>
