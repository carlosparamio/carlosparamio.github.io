---
import BaseLayout from '../layouts/BaseLayout.astro';
import OSSCard from '../components/OSSCard.astro';
import openSourceProjects from '../data/openSource.json';
---

<BaseLayout title="Open Source" description="Open source projects I've created and contributed to.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="mb-16">
      <h1 class="section-title">Open Source</h1>
      <p class="text-gray-600 max-w-2xl mb-8">
        I've contributed to the open source community with several Ruby gems. Here's a selection of my projects available on GitHub.
      </p>
      <div class="flex gap-8">
        <div style="width: 64px; text-align: center;">
          <img src="/images/badges/arctic-code-vault.png" alt="Arctic Code Vault Contributor" width="64" height="64" />
          <p class="text-xs text-gray-500 mt-2">Arctic Code Vault</p>
        </div>
        <div style="width: 64px; text-align: center;">
          <img src="/images/badges/pull-shark.png" alt="Pull Shark" width="64" height="64" />
          <p class="text-xs text-gray-500 mt-2">Pull Shark</p>
        </div>
        <div style="width: 64px; text-align: center;">
          <img src="/images/badges/starstruck.png" alt="Starstruck" width="64" height="64" />
          <p class="text-xs text-gray-500 mt-2">Starstruck</p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {openSourceProjects.map((project) => (
        <OSSCard 
          name={project.name}
          description={project.description}
          url={project.url}
        />
      ))}
    </div>

    <div class="text-center">
      <a 
        href="https://github.com/carlosparamio" 
        class="btn-github"
        target="_blank"
        rel="noopener"
      >
        <svg class="btn-github-icon" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
        </svg>
        View All on GitHub
      </a>
    </div>
  </section>
</BaseLayout>
