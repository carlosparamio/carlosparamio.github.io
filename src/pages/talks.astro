---
import BaseLayout from '../layouts/BaseLayout.astro';
import talks from '../data/talks.json';

const talksByYear = talks.reduce((acc, talk) => {
  if (!acc[talk.year]) acc[talk.year] = [];
  acc[talk.year].push(talk);
  return acc;
}, {} as Record<number, typeof talks>);

const years = Object.keys(talksByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Talks" description="Conference talks and presentations by Carlos Paramio.">
  <section class="section shell" aria-labelledby="talks-heading">
    <header class="section-heading">
      <span class="section-kicker">Speaking</span>
      <h1 id="talks-heading">Talks</h1>
      <p class="section-description">Conference talks and presentations at tech events.</p>
    </header>

    <div class="timeline">
      {years.map((year) => (
        <section class="timeline-year">
          <div class="timeline-year-label" aria-hidden="true">{year}</div>
          <div class="timeline-items">
            {talksByYear[Number(year)].map((item) => (
              <div class="timeline-item">
                <span class="timeline-dot" aria-hidden="true"></span>
                <article class="card timeline-card">
                  <h3 class="timeline-title">{item.event}</h3>
                  <p class="timeline-meta">{item.location}</p>
                  {item.talk && <p class="timeline-detail">{item.talk}</p>}
                  {item.role && <p class="timeline-detail">{item.role}</p>}
                </article>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .timeline {
    display: grid;
    gap: clamp(2rem, 5vw, var(--space-12));
  }

  .timeline-year {
    display: grid;
    grid-template-columns: minmax(70px, 120px) 1fr;
    gap: clamp(1.5rem, 4vw, var(--space-8));
    align-items: start;
  }

  .timeline-year-label {
    font-size: var(--text-sm);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-text-subtle);
    padding-top: var(--space-2);
  }

  .timeline-items {
    position: relative;
    display: grid;
    gap: var(--space-4);
    padding-left: var(--space-6);
  }

  .timeline-items::before {
    content: '';
    position: absolute;
    left: 0.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border-subtle);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .timeline-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 3px solid color-mix(in oklch, var(--color-accent) 60%, transparent 40%);
    background: var(--color-background);
    margin-top: var(--space-3);
  }

  .timeline-card {
    gap: var(--space-2);
  }

  .timeline-title {
    font-size: var(--text-lg);
    color: var(--color-primary);
  }

  .timeline-meta {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  .timeline-detail {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .timeline-year {
      grid-template-columns: 1fr;
    }

    .timeline-year-label {
      padding-bottom: var(--space-2);
    }

    .timeline-items {
      padding-left: var(--space-5);
    }
  }
</style>
