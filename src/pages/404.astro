---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="section shell">
    <div class="not-found">
      <h1 class="text-display font-bold">404</h1>
      <p class="text-xl text-muted">Page not found</p>
      <a href="/" class="btn btn-primary">Go Home</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: grid;
    gap: var(--space-4);
    align-items: center;
    justify-items: center;
    text-align: center;
    padding-block: clamp(4rem, 10vw + 1rem, var(--space-24));
  }

  .not-found p {
    max-width: 28rem;
  }
</style>
