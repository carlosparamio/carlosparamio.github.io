---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import testimonials from '../data/testimonials.json';
import TestimonialCard from '../components/TestimonialCard.astro';

const services = [
  {
    title: 'Cloud Architecture',
    description: 'Design and implementation of scalable AWS architectures. From infrastructure planning to deployment automation, I help teams build resilient cloud-native systems.',
    icon: '☁️',
  },
  {
    title: 'Technical Leadership',
    description: 'Strategic guidance for development teams. Architecture reviews, technology selection, and best practices to ensure your project scales with your business.',
    icon: '🚀',
  },
  {
    title: 'System Optimization',
    description: 'Performance audits, cost optimization, and scalability improvements for existing applications. Identify bottlenecks and implement solutions that matter.',
    icon: '🔍',
  },
  {
    title: 'Mentoring & Consulting',
    description: 'Knowledge transfer for teams transitioning to cloud or modernizing legacy systems. Hands-on guidance in AWS, software architecture, and agile practices.',
    icon: '🎓',
  },
];
---

<BaseLayout title="Home">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="text-center mb-16">
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">
        <span class="gradient-text">I Design Scalable</span>
        <br />
        Cloud Architectures
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Software architect specializing in AWS cloud solutions and scalable systems. 20+ years helping enterprises and startups build robust, high-performance applications.
      </p>
      <div class="flex gap-4 justify-center mt-8">
        <a href="/about" class="btn-primary">Learn More</a>
        <a href="mailto:hola@carlosparamio.com" class="btn-secondary">Get in Touch</a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20">
      {services.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>

    <div class="text-center mb-8">
      <h2 class="section-title">What People Say</h2>
      <p class="text-gray-600">Don't just take my word for it.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.slice(0, 3).map((testimonial) => (
        <TestimonialCard {...testimonial} />
      ))}
    </div>

    <div class="text-center mt-10">
      <a href="/about" class="text-accent font-medium hover:underline">
        See all testimonials →
      </a>
    </div>
  </section>
</BaseLayout>
