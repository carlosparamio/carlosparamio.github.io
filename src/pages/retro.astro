---
import BaseLayout from '../layouts/BaseLayout.astro';

const games = [
  { 
    title: 'El Espía', 
    file: 'espia.sna', 
    wosUrl: 'https://worldofspectrum.net/item/0021010' 
  },
  { 
    title: 'Lobos', 
    file: 'lobos.sna', 
    wosUrl: 'https://worldofspectrum.net/item/0021012' 
  },
  { 
    title: 'Omán', 
    file: 'oman.sna', 
    wosUrl: 'https://worldofspectrum.net/item/0021011' 
  },
];
---

<BaseLayout title="Retro" description="A collection of ZX Spectrum adventure games from my childhood.">
  <section class="section shell" aria-labelledby="retro-heading">
    <header class="section-heading">
      <span class="section-kicker">ZX Spectrum</span>
      <h1 id="retro-heading">Retro Games</h1>
      <p class="section-description">
        Adventure games from my childhood, built with PAWS (Professional Adventure Writing System). Play them directly in your browser.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {games.map((game) => (
        <div class="card retro-card">
          <h3 class="retro-card-title">{game.title}</h3>
          <div class="retro-actions">
            <a class="btn btn-secondary retro-link" href={game.wosUrl} target="_blank" rel="noopener">
              View on WoS
            </a>
            <button class="btn btn-primary retro-play" type="button" data-game={game.file}>
              Play Now
            </button>
          </div>
        </div>
      ))}
    </div>

    <div id="emulator-container" class="retro-emulator" style="display: none;">
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-heading mb-4">How to Play</h2>
        <div class="retro-help">
          <ul class="retro-list">
            <li>Escribe órdenes en español usando <strong>VERBO + NOMBRE</strong> (ej: COGER LLAVE, ABRIR PUERTA, EXAMINAR MESA).</li>
            <li>Movimiento: <strong>N</strong> (norte), <strong>S</strong> (sur), <strong>E</strong> (este), <strong>O</strong> (oeste), <strong>SUBIR</strong>, <strong>BAJAR</strong>.</li>
            <li>Atajos: <strong>M</strong> o <strong>MIRAR</strong> (describir lugar), <strong>I</strong> o <strong>INVENTARIO</strong> (ver objetos), <strong>EX</strong> o <strong>EXAMINAR</strong>.</li>
            <li>Otros: <strong>COGER</strong>, <strong>DEJAR</strong>, <strong>ABRIR</strong>, <strong>METER</strong>, <strong>SACAR</strong>, <strong>HABLAR CON</strong>, <strong>DAR objeto A personaje</strong>.</li>
          </ul>
        </div>
      </div>
      <div id="jsspeccy" class="retro-emulator-wrapper"></div>
      <div class="retro-emulator-footer">
        <button id="close-emulator" class="btn btn-secondary btn-close-emulator" type="button">Close</button>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline src="/jsspeccy/jsspeccy.js"></script>
<script is:inline>
  function initRetroEmulator() {
    var playButtons = document.querySelectorAll('.retro-play');
    var container = document.getElementById('emulator-container');
    var closeButton = document.getElementById('close-emulator');
    var emu = null;

    playButtons.forEach(function(button) {
      button.addEventListener('click', function() {
        var gameFile = button.getAttribute('data-game');
        if (gameFile && container) {
          if (emu) {
            emu.exit();
            emu = null;
          }
          var jsspeccyDiv = document.getElementById('jsspeccy');
          if (jsspeccyDiv) jsspeccyDiv.innerHTML = '';
          
          container.style.display = 'block';
          
          if (typeof JSSpeccy === 'function') {
            emu = JSSpeccy(jsspeccyDiv, {
              zoom: 2,
              machine: 128,
              autoStart: true,
              openUrl: '/spectrum/' + gameFile,
              showUI: false
            });
          }
          
          container.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });

    if (closeButton) {
      closeButton.addEventListener('click', function() {
        if (container) {
          container.style.display = 'none';
          if (emu) {
            emu.exit();
            emu = null;
          }
          var jsspeccyDiv = document.getElementById('jsspeccy');
          if (jsspeccyDiv) jsspeccyDiv.innerHTML = '';
        }
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initRetroEmulator);
  document.addEventListener('astro:page-load', initRetroEmulator);
</script>

<style>
  .retro-card {
    display: grid;
    gap: var(--space-4);
    text-align: left;
  }

  .retro-card-title {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-primary);
  }

  .retro-actions {
    display: grid;
    gap: var(--space-3);
  }

  .retro-link,
  .retro-play {
    width: 100%;
  }

  .retro-emulator {
    margin-top: clamp(2.5rem, 5vw + 1rem, var(--space-12));
    padding-bottom: clamp(2rem, 4vw + 1rem, var(--space-12));
  }

  .retro-help {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .retro-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .retro-list li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    padding-left: var(--space-4);
    position: relative;
  }

  .retro-list li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 600;
  }

  .retro-list strong {
    color: var(--color-text);
  }

  .retro-emulator-wrapper {
    background-color: #000;
    border-radius: 0.75rem;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 4 / 3;
    position: relative;
  }

  .retro-emulator-wrapper :global(> div) {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
  }

  .retro-emulator-wrapper :global(canvas) {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain;
  }

  .retro-emulator-wrapper :global(button) {
    z-index: 10;
  }

  .retro-emulator-wrapper :global(menu),
  .retro-emulator-wrapper :global(ul),
  .retro-emulator-wrapper :global(div > div:first-child) {
    display: none !important;
  }

  .retro-emulator-wrapper :global(canvas) {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
  }

  .retro-emulator-footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-4);
  }

  @media (prefers-reduced-motion: reduce) {
    .retro-actions .btn,
    .retro-emulator-footer .btn {
      transition: none;
    }
  }
</style>
