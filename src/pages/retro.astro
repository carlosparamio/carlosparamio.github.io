---
import BaseLayout from '../layouts/BaseLayout.astro';

const games = [
  { 
    title: 'El Espía', 
    file: 'espia.sna', 
    wosUrl: 'https://worldofspectrum.net/item/0021010' 
  },
  { 
    title: 'Lobos', 
    file: 'lobos.sna', 
    wosUrl: 'https://worldofspectrum.net/item/0021012' 
  },
  { 
    title: 'Omán', 
    file: 'oman.sna', 
    wosUrl: 'https://worldofspectrum.net/item/0021011' 
  },
];
---

<BaseLayout title="Retro" description="A collection of ZX Spectrum adventure games from my childhood.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="text-center mb-16">
      <h1 class="section-title">Retro Games</h1>
      <p class="text-gray-600 max-w-2xl mx-auto">
        A collection of ZX Spectrum adventure games from my childhood. These games were created using PAWS (Professional Adventure Writing System). Play them directly in your browser!
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {games.map((game) => (
        <div class="card retro-card">
          <div class="retro-card-icon">🕹️</div>
          <h3 class="retro-card-title">{game.title}</h3>
          <button class="btn-wos" onclick={`window.open('${game.wosUrl}', '_blank')`}>
            View on WoS
          </button>
          <button class="btn-retro" data-game={game.file}>
            ▶ Play Now
          </button>
        </div>
      ))}
    </div>

    <div class="bg-gray-50 rounded-xl p-8">
      <h2 class="retro-section-title">Comandos</h2>
      <p class="retro-text">
        Escribe órdenes en español usando <strong>VERBO + NOMBRE</strong> (ej: COGER LLAVE, ABRIR PUERTA, EXAMINAR MESA).<br>
        Movimiento: <strong>N</strong> (norte), <strong>S</strong> (sur), <strong>E</strong> (este), <strong>O</strong> (oeste), <strong>SUBIR</strong>, <strong>BAJAR</strong>.<br>
        Atajos: <strong>M</strong> o <strong>MIRAR</strong> (describir lugar), <strong>I</strong> o <strong>INVENTARIO</strong> (ver objetos), <strong>EX</strong> o <strong>EXAMINAR</strong>.<br>
        Otros: <strong>COGER</strong>, <strong>DEJAR</strong>, <strong>ABRIR</strong>, <strong>METER</strong>, <strong>SACAR</strong>, <strong>HABLAR CON</strong>, <strong>DAR objeto A personaje</strong>.
      </p>
    </div>

    <div id="emulator-container" class="mt-12" style="display: none;">
      <div id="jsspeccy" class="retro-emulator-wrapper"></div>
      <div class="retro-emulator-footer">
        <button id="close-emulator" class="btn-close-emulator">✕ Close Emulator</button>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline src="/jsspeccy/jsspeccy.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var playButtons = document.querySelectorAll('.btn-retro');
    var container = document.getElementById('emulator-container');
    var closeButton = document.getElementById('close-emulator');
    var emu = null;

    playButtons.forEach(function(button) {
      button.addEventListener('click', function() {
        var gameFile = button.getAttribute('data-game');
        if (gameFile && container) {
          if (emu) {
            emu.exit();
            emu = null;
          }
          var jsspeccyDiv = document.getElementById('jsspeccy');
          if (jsspeccyDiv) jsspeccyDiv.innerHTML = '';
          
          container.style.display = 'block';
          
          if (typeof JSSpeccy === 'function') {
            emu = JSSpeccy(jsspeccyDiv, {
              zoom: 2,
              machine: 128,
              autoStart: true,
              openUrl: '/spectrum/' + gameFile,
              showUI: false
            });
          }
          
          container.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });

    if (closeButton) {
      closeButton.addEventListener('click', function() {
        if (container) {
          container.style.display = 'none';
          if (emu) {
            emu.exit();
            emu = null;
          }
          var jsspeccyDiv = document.getElementById('jsspeccy');
          if (jsspeccyDiv) jsspeccyDiv.innerHTML = '';
        }
      });
    }
  });
</script>

<style>
  .retro-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .retro-card-icon { font-size: 3rem; margin-bottom: 1rem; }
  .retro-card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .btn-wos {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    background-color: transparent;
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.875rem;
    border: 2px solid var(--color-primary);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
    margin-bottom: 0.75rem;
  }
  .btn-wos:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }
  .btn-retro {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-primary);
    color: var(--color-white);
    font-weight: 500;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
  }
  .btn-retro:hover {
    background-color: var(--color-secondary);
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
  }
  .retro-section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .retro-subtitle {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .retro-list { list-style: none; padding: 0; margin: 0; }
  .retro-list li {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }
  .retro-list strong { color: var(--color-gray-700); }
  .retro-text {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    line-height: 1.6;
  }
  .retro-emulator-wrapper {
    background-color: #000;
    border-radius: 0.75rem;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 4 / 3;
    position: relative;
  }
  .retro-emulator-wrapper :global(> div) {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
  }
  .retro-emulator-wrapper :global(canvas) {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain;
  }
  .retro-emulator-wrapper :global(button) {
    z-index: 10;
  }
  .retro-emulator-wrapper :global(menu),
  .retro-emulator-wrapper :global(ul),
  .retro-emulator-wrapper :global(div > div:first-child) {
    display: none !important;
  }
  .retro-emulator-wrapper :global(canvas) {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
  }
  .retro-emulator-footer {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }
  .btn-close-emulator {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-primary);
    color: var(--color-white);
    font-weight: 500;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.2s;
  }
  .btn-close-emulator:hover {
    background-color: var(--color-secondary);
  }
</style>
