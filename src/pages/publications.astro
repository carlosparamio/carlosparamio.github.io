---
import BaseLayout from '../layouts/BaseLayout.astro';
import publications from '../data/publications.json';
---

<BaseLayout title="Publications" description="Books and articles by Carlos Paramio.">
  <section class="section shell" aria-labelledby="publications-heading">
    <header class="section-heading">
      <span class="section-kicker">Writing</span>
      <h1 id="publications-heading">Publications</h1>
      <p class="section-description">
        Books and technical articles I've written over the years.
      </p>
    </header>

    <div class="publication-group">
      <div class="publication-group-header">
        <h2 class="publication-group-title">Books</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {publications.books.map((book) => (
          <a href={book.url} target="_blank" rel="noopener noreferrer" class="card card-link publication-card">
            <span class="publication-kicker">{book.type}</span>
            <h3 class="publication-title">{book.title}</h3>
            <p class="publication-meta">{book.year}{book.isbn && ` · ISBN: ${book.isbn}`}</p>
            <p class="publication-description">{book.description}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="publication-group section-divider">
      <div class="publication-group-header">
        <h2 class="publication-group-title">Technical Articles</h2>
      </div>
      <div class="publication-list">
        {publications.articles.map((article) => (
          article.url ? (
            <a href={article.url} target="_blank" rel="noopener noreferrer" class="card card-link publication-card">
              <h3 class="publication-title">{article.title}</h3>
              <p class="publication-meta">
                {article.publication}{article.year && ` (${article.year})`}{article.isbn && ` · ISBN: ${article.isbn}`}
              </p>
            </a>
          ) : (
            <div class="card publication-card" role="article">
              <h3 class="publication-title">{article.title}</h3>
              <p class="publication-meta">
                {article.publication}{article.year && ` (${article.year})`}{article.isbn && ` · ISBN: ${article.isbn}`}
              </p>
            </div>
          )
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .publication-group {
    display: grid;
    gap: clamp(1.5rem, 4vw, var(--space-8));
    margin-top: clamp(1.5rem, 3vw + 1rem, var(--space-10));
  }

  .publication-group:first-of-type {
    margin-top: 0;
  }

  .publication-group.section-divider {
    margin-top: 0;
  }

  .publication-group-header {
    display: grid;
    gap: var(--space-2);
  }

  .publication-group-title {
    font-size: var(--text-2xl);
    color: var(--color-primary);
  }

  .publication-list {
    display: grid;
    gap: var(--space-4);
  }

  .publication-card {
    gap: var(--space-2);
  }

  .publication-kicker {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .publication-title {
    font-size: var(--text-xl);
    color: var(--color-primary);
  }

  .publication-meta {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  .publication-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
