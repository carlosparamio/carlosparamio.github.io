---
interface Props {
  name: string;
  description: string;
  url: string;
}

const { name, description, url } = Astro.props;
---

<a href={url} target="_blank" rel="noopener" class="card card-link oss-card">
  <div class="oss-card-header">
    <span class="oss-card-kicker">Open Source</span>
    <h3 class="oss-card-title">{name}</h3>
    <svg class="oss-card-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
      <polyline points="15 3 21 3 21 9"/>
      <line x1="10" y1="14" x2="21" y2="3"/>
    </svg>
  </div>
  <p class="oss-card-description">{description}</p>
</a>
