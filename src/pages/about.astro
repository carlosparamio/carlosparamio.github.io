---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import testimonials from '../data/testimonials.json';
---

<BaseLayout title="About" description="Learn more about Carlos Paramio, software and cloud architect with 20+ years of experience.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 mb-20">
      <div class="lg:col-span-2">
        <h1 class="section-title">About Me</h1>
        <div class="prose prose-lg text-gray-600">
          <p class="mb-6">
            I'm a software and cloud architect with over 20 years of experience designing scalable systems. Currently at Avallain, I lead the architecture of AI-powered educational platforms serving millions of learners worldwide.
          </p>
          <p class="mb-6">
            My focus has evolved from hands-on development to strategic technical leadership: designing AWS cloud infrastructures, defining system architectures, and guiding teams through complex technical challenges.
          </p>
          <p>
            I've collaborated with startups and enterprises across Europe and the US, spoken at conferences about development practices, and contributed to open source projects. I'm passionate about building systems that are not just functional, but maintainable, scalable, and cost-effective.
          </p>
        </div>

        <div class="flex gap-4 mt-8">
          <a href="https://github.com/carlosparamio" class="btn-secondary" target="_blank" rel="noopener">
            GitHub
          </a>
          <a href="https://linkedin.com/in/carlosparamio" class="btn-primary" target="_blank" rel="noopener">
            Contact me on LinkedIn
          </a>
        </div>
      </div>

      <div class="lg:col-span-1" style="padding-left: 2rem;">
        <div class="card">
          <h3 class="font-bold text-primary mb-4">Quick Facts</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start" style="gap: 0.5rem;">
              <span class="text-accent">✓</span>
              <span>20+ years in software development</span>
            </li>
            <li class="flex items-start" style="gap: 0.5rem;">
              <span class="text-accent">✓</span>
              <span>AWS Cloud Architecture</span>
            </li>
            <li class="flex items-start" style="gap: 0.5rem;">
              <span class="text-accent">✓</span>
              <span>Scalable system design</span>
            </li>
            <li class="flex items-start" style="gap: 0.5rem;">
              <span class="text-accent">✓</span>
              <span>Technical leadership</span>
            </li>
            <li class="flex items-start" style="gap: 0.5rem;">
              <span class="text-accent">✓</span>
              <span>EdTech & SaaS platforms</span>
            </li>
            <li class="flex items-start" style="gap: 0.5rem;">
              <span class="text-accent">✓</span>
              <span>Remote-first since 2008</span>
            </li>
            <li class="flex items-start" style="gap: 0.5rem;">
              <span class="text-accent">✓</span>
              <span>English & Spanish</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mb-20">
      <h2 class="section-title mb-8">Certifications</h2>
      <div class="flex gap-6">
        <a href="https://www.credly.com/badges/84f3d3ed-969a-4070-88c2-a0b7e526a252" target="_blank" rel="noopener">
          <img src="https://images.credly.com/images/00634f82-b07f-4bbd-a6bb-53de397fc3a6/image.png" alt="AWS Certified Cloud Practitioner" width="150" height="150" />
        </a>
        <a href="https://www.credly.com/go/zPI3pR70kyH9MT8qe6xWzA" target="_blank" rel="noopener">
          <img src="https://images.credly.com/images/4d4693bb-530e-4bca-9327-de07f3aa2348/image.png" alt="AWS Certified AI Practitioner" width="150" height="150" />
        </a>
      </div>
    </div>

    <div>
      <h2 class="section-title mb-8">Testimonials</h2>
      <p class="text-gray-600 mb-10">
        Here's what some of my clients and colleagues have to say about working with me.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {testimonials.map((testimonial) => (
          <TestimonialCard {...testimonial} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
