---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import testimonials from '../data/testimonials.json';
import certifications from '../data/certifications.json';
---

<BaseLayout title="About" description="Learn more about Carlos Paramio, software and cloud architect with 20+ years of experience.">
  <section class="section shell about-intro">
    <header class="section-heading">
      <span class="section-kicker">Profile</span>
      <h1>Background</h1>
    </header>
    <div class="prose text-muted about-prose">
      <p>
        I'm a software and cloud architect with over 20 years of experience designing scalable systems. Currently at Avallain, I lead the architecture of AI-powered educational products serving millions of learners worldwide.
      </p>
      <p>
        My focus has evolved from hands-on development to strategic technical leadership: designing AWS cloud infrastructures, defining system architectures, and guiding teams through complex technical challenges.
      </p>
      <p>
        I've collaborated with startups and enterprises across Europe and the US, spoken at conferences about development practices, and contributed to open source projects. I'm passionate about building systems that are not just functional, but maintainable, scalable, and cost-effective.
      </p>
      <p>
        20+ years in software development, AWS cloud architecture, EdTech & SaaS products. Remote-first since 2008. English & Spanish.
      </p>
    </div>
    <div class="about-actions">
      <a href="https://linkedin.com/in/carlosparamio" class="btn btn-primary" target="_blank" rel="noopener me">
        Let's Connect
      </a>
      <a href="/projects" class="btn btn-secondary">Explore Projects</a>
    </div>
  </section>

  <section class="section shell section-divider" aria-labelledby="certifications-heading">
    <header class="section-heading">
      <span class="section-kicker">Credentials</span>
      <h2 id="certifications-heading">Certifications</h2>
      <p class="section-description">Continuous learning keeps my architecture decisions grounded in current cloud capabilities.</p>
    </header>
    <ul class="cert-grid">
      {certifications.map((cert) => (
        <li class="cert-item">
          <a href={cert.url} target="_blank" rel="noopener" class="card card-link cert-card">
            <img src={cert.image} alt={`Badge: ${cert.name}`} width="120" height="120" loading="lazy" />
            <span class="cert-name">{cert.name}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section id="testimonials" class="section shell section-divider" aria-labelledby="about-testimonials">
    <header class="section-heading">
      <span class="section-kicker">Testimonials</span>
      <h2 id="about-testimonials">What Colleagues Say</h2>
      <p class="section-description">Honest feedback from people I've partnered with over the years.</p>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {testimonials.map((testimonial) => (
        <TestimonialCard {...testimonial} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .about-intro {
    display: grid;
    gap: clamp(1.5rem, 4vw, var(--space-10));
    max-width: 48rem;
  }

  .about-prose {
    color: var(--color-text-muted);
  }

  .about-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: clamp(1.5rem, 4vw, var(--space-8));
    margin: 0;
    padding: 0;
  }

  .cert-item {
    list-style: none;
  }

  .cert-card {
    flex-direction: row;
    align-items: center;
    text-align: left;
    gap: var(--space-3);
  }

  .cert-card img {
    width: 120px;
    height: 120px;
    object-fit: contain;
  }

  .cert-name {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .about-intro {
      max-width: 100%;
    }

  }
</style>
