---
interface Props {
  quote: string;
  name: string;
  position: string;
  avatar: string;
  url: string;
}

const { quote, name, position, avatar, url } = Astro.props;
---

<blockquote class="card testimonial-card">
  <p class="testimonial-quote">"{quote}"</p>
  <footer class="flex items-center gap-4">
    <img 
      src={`/images/customers/${avatar}`} 
      alt={`Photo of ${name}`}
      class="testimonial-avatar"
      loading="lazy"
      width="48"
      height="48"
    />
    <div>
      <a href={url} target="_blank" rel="noopener noreferrer" class="testimonial-author">
        {name}
      </a>
      <p class="testimonial-position">{position}</p>
    </div>
  </footer>
</blockquote>
